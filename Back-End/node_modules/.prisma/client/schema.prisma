datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Part {
  id          String       @id @default(cuid())
  partNumber  String       @unique
  partDesc    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  vendorParts VendorPart[]
  ncrs        Ncr[]
  qprParts    QprPart[]
}

model Vendor {
  id                  String               @id @default(cuid())
  vendorCode          String               @unique
  vendorName          String?              @unique
  createdAt           DateTime?            @default(now())
  updatedAt           DateTime?            @updatedAt
  vendorParts         VendorPart[]
  ncrs                Ncr[]
  qprs                Qpr[]
  confirmationLetters ConfirmationLetter[]
}

model VendorPart {
  id        String   @id @default(cuid())
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
  partId    String
  part      Part     @relation(fields: [partId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vendorId, partId]) // Memastikan kombinasi part-vendor unik
}

model Ncr {
  id                         String       @id @default(cuid())
  code                       String       @unique
  date                       DateTime     @default(now())
  partId                     String
  part                       Part         @relation(fields: [partId], references: [id])
  vendorId                   String
  vendor                     Vendor       @relation(fields: [vendorId], references: [id])
  location                   Location?
  problemType                ProblemType?
  description                String?
  disposition                Disposition?
  isRequiredCustomerApproval Boolean?
  details                    Json?

  // Relasi 1-to-1 ke Progres Approval (Checksum tanda tangan digital)
  ncrApprovalProgress NcrApprovalProgress?

  // Relasi Many-to-Many ke User (Inspektur bisa lebih dari satu)
  inspectors User[] @relation("NcrInspectors")
}

model NcrApprovalProgress {
  id                          String    @id @default(cuid())
  ncrId                       String    @unique // Diperlukan unik untuk relasi 1-to-1
  ncr                         Ncr       @relation(fields: [ncrId], references: [id])
  checksumApprovalSectionHead Bytes?
  checksumApprovalDeptHead    Bytes?
  createdAt                   DateTime? @default(now())
  updatedAt                   DateTime? @default(now())
}

model User {
  id   String @id @default(cuid())
  name String
  npk  Int    @unique

  // Relasi Terbalik Many-to-Many ke Ncr
  inspectedNcrs Ncr[] @relation("NcrInspectors")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Location {
  INCOMING
  OUTGOING
  IN_PROCESS
  CUSTOMER
}

enum ProblemType {
  QUALITY
  QUANTITY
}

enum Disposition {
  RETURN_TO_VENDOR
  REWORK
  SCRAP
  ACCEPT_AS_IS
  REPAIR
  REGRADE
}

model Qpr {
  id                 String               @id @default(cuid())
  qprNumber          String               @unique
  date               DateTime             @default(now())
  vendorId           String
  vendor             Vendor               @relation(fields: [vendorId], references: [id])
  status             QprStatus            @default(WAITING_APPROVAL)
  requiredRole       String
  refNcrNumber       String?
  problem            String?
  claimType          String?
  totalQty           Int
  totalQtyNg         Int
  totalStdAllowance  Int
  billableQty        Int
  claimAmount        Float?
  qprParts           QprPart[]
  approvalProgress   QprApprovalProgress?
  confirmationLetter ConfirmationLetter?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model QprPart {
  id           String   @id @default(cuid())
  qprId        String
  qpr          Qpr      @relation(fields: [qprId], references: [id])
  partId       String
  part         Part     @relation(fields: [partId], references: [id])
  totalQty     Int
  qtyNg        Int
  stdAllowance Int
  qtyClaim     Int
  unitPrice    Float?
  taxRate      Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model QprApprovalProgress {
  id                  String   @id @default(cuid())
  qprId               String   @unique
  qpr                 Qpr      @relation(fields: [qprId], references: [id])
  checksumSectionHead Bytes?
  checksumDeptHead    Bytes?
  checksumDivHead     Bytes?
  checksumVendor      Bytes?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ConfirmationLetter {
  id         String      @id @default(cuid())
  clNumber   String      @unique
  dateSent   DateTime    @default(now())
  qprId      String      @unique
  qpr        Qpr         @relation(fields: [qprId], references: [id])
  vendorId   String
  vendor     Vendor      @relation(fields: [vendorId], references: [id])
  amount     Float
  status     ClStatus    @default(PENDING)
  sscBilling SscBilling?
  sscPayment SscPayment?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model SscBilling {
  id          String             @id @default(cuid())
  clId        String             @unique
  cl          ConfirmationLetter @relation(fields: [clId], references: [id])
  billingNo   String             @unique
  billingDate DateTime           @default(now())
  totalAmount Float
  status      BillingStatus      @default(UNPAID)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model SscPayment {
  id          String             @id @default(cuid())
  clId        String             @unique
  cl          ConfirmationLetter @relation(fields: [clId], references: [id])
  paymentNo   String             @unique
  paymentDate DateTime           @default(now())
  amountPaid  Float
  bankName    String?
  accountNo   String?
  status      PaymentStatus      @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum QprStatus {
  WAITING_APPROVAL
  WAITING_VENDOR
  APPROVED_BY_VENDOR
  APPROVED
  CLOSED
  CLOSED_PAID
}

enum ClStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillingStatus {
  UNPAID
  PAID
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
